-- phele independent table ya entities banayege
CREATE TABLE course_category (
    course_cat_id SERIAL PRIMARY KEY,
    course_cat_desc VARCHAR(255) NOT NULL,
    created_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE course_type (
    course_type_id SERIAL PRIMARY KEY,
    course_type_name VARCHAR(100) NOT NULL,
    is_active BOOLEAN DEFAULT TRUE
);

CREATE TABLE student (
    student_id SERIAL PRIMARY KEY,
    student_name VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    created_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- phir hum main table banayege course module ka
CREATE TABLE course (
    course_id SERIAL PRIMARY KEY,
    course_name VARCHAR(255) NOT NULL,
    course_desc TEXT,
    course_category_id INT REFERENCES course_category(course_cat_id),
    course_type_id INT REFERENCES course_type(course_type_id),
    course_duration VARCHAR(50),
    course_start_date DATE,
    is_active BOOLEAN DEFAULT TRUE,
    created_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Derived tables banayenge
CREATE TABLE course_topics (
    course_topic_id SERIAL PRIMARY KEY,
    course_id INT REFERENCES course(course_id),
    course_topic_name VARCHAR(255) NOT NULL,
    sequence INT NOT NULL
);

CREATE TABLE course_price (
    course_price_id SERIAL PRIMARY KEY,
    course_id INT REFERENCES course(course_id),
    course_price_mrp NUMERIC(10, 2) NOT NULL,
    course_price_discount NUMERIC(10, 2),
    coupon_code VARCHAR(50)
);

CREATE TABLE course_schedule (
    schedule_id SERIAL PRIMARY KEY,
    course_id INT REFERENCES course(course_id),
    instructor_id INT,
    schedule_name VARCHAR(255),
    description TEXT,
    schedule_date DATE,
    start_time TIME,
    end_time TIME,
    meeting_link TEXT,
    active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE course_rating (
    rating_id SERIAL PRIMARY KEY,
    course_id INT REFERENCES course(course_id),
    rating_count INT DEFAULT 0
);

-- Daily ka Transxation wale table create karte hai
CREATE TABLE course_registration (
    registration_id SERIAL PRIMARY KEY,
    course_id INT REFERENCES course(course_id),
    student_id INT REFERENCES student(student_id),
    payment_status VARCHAR(50),
    is_course_success BOOLEAN,
    created_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE course_history (
    course_history_id SERIAL PRIMARY KEY,
    course_id INT REFERENCES course(course_id),
    student_id INT REFERENCES student(student_id),
    created_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE (course_id, student_id)
);

